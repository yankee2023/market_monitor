<Window x:Class="MarketMonitor.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:infra="clr-namespace:MarketMonitor.Shared.Infrastructure"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Tokyo Market Technical" Height="820" Width="1240"
        MinHeight="700" MinWidth="960"
        WindowStartupLocation="Manual"
        ResizeMode="CanResizeWithGrip">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Resources/MainWindowStyles.xaml" />
            </ResourceDictionary.MergedDictionaries>
            <infra:BooleanToGridLengthConverter x:Key="SidebarColumnWidthConverter" TrueWidth="0" FalseWidth="2.2" FalseUnitType="Star" />
            <infra:BooleanToGridLengthConverter x:Key="SidebarSplitterWidthConverter" TrueWidth="0" FalseWidth="6" />
            <infra:MaximumDoubleMultiConverter x:Key="MaximumDoubleMultiConverter" />
            <infra:DoubleDivisionConverter x:Key="DoubleDivisionConverter" />
        </ResourceDictionary>
    </Window.Resources>
    <Grid Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Padding="10,8" Background="#0E2A47" CornerRadius="10" Margin="0,0,0,8">
            <DockPanel>
                <StackPanel DockPanel.Dock="Left">
                    <TextBlock Text="Tokyo Market Technical" FontSize="20" FontWeight="Bold" Foreground="White" />
                    <TextBlock Text="東証プライム / スタンダード / グロース銘柄のテクニカル分析ダッシュボード" FontSize="11" Foreground="#D8E9FA" Margin="0,2,0,0" />
                </StackPanel>
                <TextBlock DockPanel.Dock="Right" Text="チャート中心で分析" VerticalAlignment="Center" Foreground="#D8E9FA" FontSize="11" FontWeight="SemiBold" />
            </DockPanel>
        </Border>

        <Border Grid.Row="1" Padding="8" Background="#F5F8FC" CornerRadius="10" Margin="0,0,0,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" MinWidth="220" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" VerticalAlignment="Center" Margin="0,0,8,0" Text="銘柄名/コード" FontWeight="SemiBold" />
                <TextBox Grid.Column="1" Text="{Binding Symbol, UpdateSourceTrigger=PropertyChanged}" Padding="8,4" Margin="0,0,10,0"
                         ToolTip="例: 7203 / トヨタ / 三菱商事">
                    <TextBox.InputBindings>
                        <KeyBinding Key="Enter" Command="{Binding ApplySymbolCommand}" />
                    </TextBox.InputBindings>
                </TextBox>

                <Button Grid.Column="2" Content="表示" Command="{Binding ApplySymbolCommand}" Padding="16,6" Margin="0,0,10,0" />
                <TextBlock Grid.Column="3" VerticalAlignment="Center" Text="Enter でも表示" Margin="0,0,10,0" Style="{StaticResource MutedCaptionTextStyle}" />
                <Button Grid.Column="4" Content="{Binding SidebarToggleText}" Command="{Binding ToggleSidebarCommand}" Style="{StaticResource ToolbarGhostButtonStyle}" />
            </Grid>
        </Border>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="7*" MinWidth="0" />
                <ColumnDefinition Width="{Binding IsSidebarCollapsed, Converter={StaticResource SidebarSplitterWidthConverter}}" />
                <ColumnDefinition Width="{Binding IsSidebarCollapsed, Converter={StaticResource SidebarColumnWidthConverter}}" MinWidth="0" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Padding="10" Style="{StaticResource CardBorderStyle}">
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" CanContentScroll="False">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <DockPanel Margin="0,0,0,4">
                        <TextBlock DockPanel.Dock="Left" Text="チャート" FontSize="13" FontWeight="SemiBold" Foreground="#23374D" />
                        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                        </StackPanel>
                    </DockPanel>

                    <Grid Grid.Row="1" Margin="0,0,0,6">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="8" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Row="0" Grid.Column="0" Orientation="Vertical">
                            <TextBlock Text="表示期間" Margin="0,0,0,4" Style="{StaticResource MutedCaptionTextStyle}" />
                            <WrapPanel>
                                <Button Content="日足" Command="{Binding ShowDailyCandlesCommand}" Style="{StaticResource DailyCandleButtonStyle}" Margin="0,0,6,6" />
                                <Button Content="週足" Command="{Binding ShowWeeklyCandlesCommand}" Style="{StaticResource WeeklyCandleButtonStyle}" Margin="0,0,10,6" />
                                <Button Content="1か月" Command="{Binding ShowOneMonthCandlesCommand}" Style="{StaticResource OneMonthButtonStyle}" Margin="0,0,6,6" />
                                <Button Content="3か月" Command="{Binding ShowThreeMonthsCandlesCommand}" Style="{StaticResource ThreeMonthsButtonStyle}" Margin="0,0,6,6" />
                                <Button Content="6か月" Command="{Binding ShowSixMonthsCandlesCommand}" Style="{StaticResource SixMonthsButtonStyle}" Margin="0,0,6,6" />
                                <Button Content="1年" Command="{Binding ShowOneYearCandlesCommand}" Style="{StaticResource OneYearButtonStyle}" Margin="0,0,6,6" />
                            </WrapPanel>
                        </StackPanel>

                        <StackPanel Grid.Row="0" Grid.Column="2" Orientation="Vertical">
                            <TextBlock Text="表示指標" Margin="0,0,0,4" Style="{StaticResource MutedCaptionTextStyle}" />
                            <ItemsControl ItemsSource="{Binding JapaneseChartIndicatorOptions}"
                                          ItemTemplate="{StaticResource JapaneseChartIndicatorOptionTemplate}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                            </ItemsControl>
                        </StackPanel>

                        <Grid Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="3" Margin="0,2,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="12" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <Expander Grid.Column="0" VerticalAlignment="Top" HorizontalAlignment="Left" Margin="0,0,0,8" IsExpanded="True"
                                      Header="分析ライン操作" FontSize="10" Foreground="#60788F">
                                <Border Padding="8,8,8,6" Background="#F8FBFF" BorderBrush="#DBE7F3" BorderThickness="1" CornerRadius="8" Margin="0,4,0,0">
                                    <StackPanel Orientation="Vertical">
                                        <WrapPanel Margin="0,0,0,4">
                                            <Button Content="自動生成を追加" Click="OnAppendAutoAnalysisLinesClick" Style="{StaticResource ToolbarGhostButtonStyle}" Margin="0,0,8,6" />
                                            <Button Content="{Binding AnalysisLineActionText}" Click="OnToggleManualAnalysisLineDrawingClick" Style="{StaticResource ToolbarGhostButtonStyle}" Margin="0,0,8,6" />
                                            <Button Content="選択線を削除" Command="{Binding RemoveSelectedAnalysisLineCommand}" Style="{StaticResource ToolbarGhostButtonStyle}" Margin="0,0,8,6" />
                                            <Button Content="全消去" Command="{Binding ClearAnalysisLinesCommand}" Style="{StaticResource ToolbarGhostButtonStyle}" Margin="0,0,0,6" />
                                        </WrapPanel>
                                        <TextBlock Text="{Binding AnalysisLineStatusText}" Foreground="#60788F" FontSize="10" TextWrapping="Wrap" />
                                    </StackPanel>
                                </Border>
                            </Expander>

                            <Expander Grid.Column="2" VerticalAlignment="Top" Margin="0,0,0,8" IsExpanded="True"
                                      Header="各線の見方" FontSize="10" Foreground="#60788F">
                                <Border Padding="8,8,8,6" Background="#F8FBFF" BorderBrush="#DBE7F3" BorderThickness="1" CornerRadius="8" Margin="0,4,0,0">
                                    <StackPanel Orientation="Vertical">
                                        <Border Background="#F6F9FD" BorderBrush="#D7E4F2" BorderThickness="1"
                                                CornerRadius="8" Padding="8,6" Margin="0,0,0,6">
                                            <TextBlock Text="{Binding AnalysisLineQuickGuideText}" Foreground="#486078" FontSize="10" TextWrapping="Wrap" />
                                        </Border>

                                        <ItemsControl ItemsSource="{Binding JapaneseAnalysisLineTypeOptions}" Margin="0,8,0,0">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <WrapPanel />
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Margin="0,0,8,8" Padding="8,6" Background="#F5F8FC" BorderBrush="#D8E2ED" BorderThickness="1" CornerRadius="8">
                                                        <StackPanel>
                                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                                                <Canvas Width="24" Height="8" Margin="0,0,6,0">
                                                                    <Polyline Points="0,4 24,4"
                                                                              Stroke="{Binding StrokeColor}"
                                                                              StrokeThickness="2.2"
                                                                              StrokeDashArray="{Binding StrokeDashArray}"
                                                                              StrokeStartLineCap="Round"
                                                                              StrokeEndLineCap="Round" />
                                                                </Canvas>
                                                                <TextBlock Text="{Binding DisplayName}" FontSize="11" FontWeight="SemiBold" Foreground="#23374D" />
                                                            </StackPanel>
                                                            <TextBlock Text="{Binding Description}" FontSize="10" Foreground="#60788F" TextWrapping="Wrap" />
                                                        </StackPanel>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                        <Expander Header="自動生成の仕組みを確認する" Margin="0,6,0,0"
                                                  FontSize="10" Foreground="#60788F" IsExpanded="False">
                                            <Border Background="#F0F7FF" BorderBrush="#C7DFF7" BorderThickness="1"
                                                    CornerRadius="6" Padding="10,8" Margin="0,4,0,0">
                                                <StackPanel>
                                                    <TextBlock Text="■ トレンドライン" FontSize="10" FontWeight="SemiBold"
                                                               Foreground="#7C3AED" Margin="0,0,0,3" />
                                                    <TextBlock FontSize="10" Foreground="#445566" TextWrapping="Wrap" Margin="0,0,0,8"
                                                               Text="終値の線形回帰でトレンド方向を判定し、上昇なら安値のピボット点、下降なら高値のピボット点から「価格差＋期間スパン」が最大のペアを選んで全幅に延長します。ピボット点は前後 2 本と比較した局所最安値／最高値です。" />
                                                    <TextBlock Text="■ 支持線" FontSize="10" FontWeight="SemiBold"
                                                               Foreground="#0F766E" Margin="0,0,0,3" />
                                                    <TextBlock FontSize="10" Foreground="#445566" TextWrapping="Wrap" Margin="0,0,0,8"
                                                               Text="安値のピボット点を価格帯の下半分に絞り、価格幅の 2.5% 以内に集まる点をクラスタとみなして最多反発クラスタの平均値に水平線を引きます。クラスタが見つからない場合は期間最安値に引きます。" />
                                                    <TextBlock Text="■ 抵抗線" FontSize="10" FontWeight="SemiBold"
                                                               Foreground="#DC2626" Margin="0,0,0,3" />
                                                    <TextBlock FontSize="10" Foreground="#445566" TextWrapping="Wrap"
                                                               Text="高値のピボット点を価格帯の上半分に絞り、同様のクラスタ探索で最多跳ね返しクラスタの平均値に水平線を引きます。クラスタが見つからない場合は期間最高値に引きます。" />
                                                </StackPanel>
                                            </Border>
                                        </Expander>
                                    </StackPanel>
                                </Border>
                            </Expander>
                        </Grid>
                    </Grid>

                    <Border Grid.Row="2" Background="#F7FAFD" CornerRadius="8" Padding="8" BorderBrush="#E2EBF4" BorderThickness="1">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*" MinHeight="260" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <Grid Grid.Row="0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="56" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <Grid Grid.Column="0" Margin="0,0,8,20">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <TextBlock Grid.Row="0" Text="{Binding JapaneseCandlestickYAxisTitle}" Margin="0,0,0,6" Style="{StaticResource MutedCaptionTextStyle}" FontWeight="SemiBold" />
                                    <Grid Grid.Row="1">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="*" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>

                                        <TextBlock Grid.Row="0" Text="{Binding JapaneseCandlestickMaxPriceLabel}" FontSize="10" Foreground="#60788F" />
                                        <TextBlock Grid.Row="1" Text="{Binding JapaneseCandlestickMidPriceLabel}" FontSize="10" Foreground="#60788F" VerticalAlignment="Center" />
                                        <TextBlock Grid.Row="2" Text="{Binding JapaneseCandlestickMinPriceLabel}" FontSize="10" Foreground="#60788F" VerticalAlignment="Bottom" />
                                    </Grid>
                                </Grid>

                                <Grid Grid.Column="1">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="*" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <ScrollViewer x:Name="MainChartScrollViewer"
                                                  Grid.Row="0"
                                                  HorizontalScrollBarVisibility="Auto"
                                                  VerticalScrollBarVisibility="Disabled"
                                                  infra:ScrollViewerSyncBehavior.GroupName="JapaneseChartHorizontal">
                                        <Grid x:Name="MainCandlestickContentGrid">
                                            <Grid.Width>
                                                <MultiBinding Converter="{StaticResource MaximumDoubleMultiConverter}">
                                                    <Binding Path="JapaneseCandlestickCanvasWidth" />
                                                    <Binding ElementName="MainChartScrollViewer" Path="ActualWidth" />
                                                </MultiBinding>
                                            </Grid.Width>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="*" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>

                                              <Grid x:Name="MainCandlestickPlotViewport"
                                                  Grid.Row="0"
                                                  ClipToBounds="True"
                                                  PreviewMouseLeftButtonDown="OnChartPreviewMouseLeftButtonDown"
                                                  PreviewMouseMove="OnChartPreviewMouseMove"
                                                  PreviewMouseLeftButtonUp="OnChartPreviewMouseLeftButtonUp">
                                                <Border HorizontalAlignment="Right"
                                                        VerticalAlignment="Top"
                                                        Margin="0,8,8,0"
                                                        Padding="8,4"
                                                        Background="#ECF3FB"
                                                        BorderBrush="#D4E0ED"
                                                        BorderThickness="1"
                                                        CornerRadius="10"
                                                        Panel.ZIndex="2"
                                                        IsHitTestVisible="False">
                                                    <WrapPanel>
                                                        <StackPanel Orientation="Horizontal" Margin="0,0,10,0">
                                                            <Ellipse Width="8" Height="8" Fill="#D62828" VerticalAlignment="Center" />
                                                            <TextBlock Text="陽線" Margin="6,0,0,0" VerticalAlignment="Center" Style="{StaticResource MutedCaptionTextStyle}" />
                                                        </StackPanel>
                                                        <StackPanel Orientation="Horizontal" Margin="0,0,10,0">
                                                            <Ellipse Width="8" Height="8" Fill="#1D4ED8" VerticalAlignment="Center" />
                                                            <TextBlock Text="陰線" Margin="6,0,0,0" VerticalAlignment="Center" Style="{StaticResource MutedCaptionTextStyle}" />
                                                        </StackPanel>
                                                        <ItemsControl ItemsSource="{Binding VisibleJapaneseOverlayIndicators}"
                                                                      Style="{StaticResource VisibleJapaneseChartIndicatorsStyle}"
                                                                      ItemTemplate="{StaticResource OverlayIndicatorLegendTemplate}">
                                                            <ItemsControl.ItemsPanel>
                                                                <ItemsPanelTemplate>
                                                                    <StackPanel Orientation="Horizontal" />
                                                                </ItemsPanelTemplate>
                                                            </ItemsControl.ItemsPanel>
                                                        </ItemsControl>
                                                    </WrapPanel>
                                                </Border>

                                                <Grid x:Name="MainCandlestickScaledGrid"
                                                      Height="260"
                                                      Width="{Binding ElementName=MainCandlestickContentGrid, Path=ActualWidth}"
                                                      VerticalAlignment="Top"
                                                      RenderTransformOrigin="0.5,0">
                                                    <Grid.RenderTransform>
                                                        <ScaleTransform ScaleY="{Binding ElementName=MainCandlestickPlotViewport, Path=ActualHeight, Converter={StaticResource DoubleDivisionConverter}, ConverterParameter=260}" />
                                                    </Grid.RenderTransform>

                                                    <Grid IsHitTestVisible="False">
                                                        <Grid.RowDefinitions>
                                                            <RowDefinition Height="Auto" />
                                                            <RowDefinition Height="*" />
                                                            <RowDefinition Height="Auto" />
                                                        </Grid.RowDefinitions>

                                                        <Border Grid.Row="0" Height="1" Background="#D7E3EF" VerticalAlignment="Top" />
                                                        <Border Grid.Row="1" Height="1" Background="#DDE7F1" VerticalAlignment="Center" />
                                                        <Border Grid.Row="2" Height="1" Background="#D7E3EF" VerticalAlignment="Bottom" />
                                                    </Grid>

                                                    <ItemsControl ItemsSource="{Binding VisibleJapaneseOverlayIndicators}" Width="{Binding ElementName=MainCandlestickScaledGrid, Path=ActualWidth}" Height="260" IsHitTestVisible="False">
                                                        <ItemsControl.ItemsPanel>
                                                            <ItemsPanelTemplate>
                                                                <Grid />
                                                            </ItemsPanelTemplate>
                                                        </ItemsControl.ItemsPanel>
                                                        <ItemsControl.ItemTemplate>
                                                            <DataTemplate>
                                                                <Polyline Points="{Binding Points}" Stroke="{Binding StrokeColor}" StrokeThickness="{Binding StrokeThickness}"
                                                                          StrokeDashArray="{Binding StrokeDashArray}" StrokeLineJoin="Round"
                                                                          StrokeStartLineCap="Round" StrokeEndLineCap="Round" Opacity="0.95" />
                                                            </DataTemplate>
                                                        </ItemsControl.ItemTemplate>
                                                    </ItemsControl>

                                                    <ItemsControl ItemsSource="{Binding JapaneseAnalysisLines}"
                                                                  ItemTemplate="{StaticResource ChartAnalysisLineTemplate}"
                                                                  Width="{Binding ElementName=MainCandlestickScaledGrid, Path=ActualWidth}"
                                                                  Height="260"
                                                                  Panel.ZIndex="1"
                                                                  IsHitTestVisible="False">
                                                        <ItemsControl.ItemsPanel>
                                                            <ItemsPanelTemplate>
                                                                <Grid />
                                                            </ItemsPanelTemplate>
                                                        </ItemsControl.ItemsPanel>
                                                    </ItemsControl>

                                                    <ItemsControl ItemsSource="{Binding JapanesePendingAnalysisPoints}"
                                                                  ItemTemplate="{StaticResource ChartAnalysisPointTemplate}"
                                                                  Width="{Binding ElementName=MainCandlestickScaledGrid, Path=ActualWidth}"
                                                                  Height="260"
                                                                  Panel.ZIndex="2"
                                                                  IsHitTestVisible="False">
                                                        <ItemsControl.ItemsPanel>
                                                            <ItemsPanelTemplate>
                                                                <Grid />
                                                            </ItemsPanelTemplate>
                                                        </ItemsControl.ItemsPanel>
                                                    </ItemsControl>

                                                    <ItemsControl ItemsSource="{Binding JapaneseCandlesticks}"
                                                                  ItemTemplate="{StaticResource JapaneseCandlestickTemplate}">
                                                        <ItemsControl.ItemsPanel>
                                                            <ItemsPanelTemplate>
                                                                <StackPanel Orientation="Horizontal" />
                                                            </ItemsPanelTemplate>
                                                        </ItemsControl.ItemsPanel>
                                                    </ItemsControl>
                                                </Grid>

                                            </Grid>

                                            <ItemsControl Grid.Row="1" ItemsSource="{Binding JapaneseCandlesticks}"
                                                          ItemTemplate="{StaticResource JapaneseCandlestickAxisLabelTemplate}">
                                                <ItemsControl.ItemsPanel>
                                                    <ItemsPanelTemplate>
                                                        <StackPanel Orientation="Horizontal" />
                                                    </ItemsPanelTemplate>
                                                </ItemsControl.ItemsPanel>
                                            </ItemsControl>
                                        </Grid>
                                    </ScrollViewer>

                                    <TextBlock Grid.Row="1" Text="{Binding JapaneseCandlestickXAxisTitle}" HorizontalAlignment="Right" Margin="0,6,4,0" Style="{StaticResource MutedCaptionTextStyle}" FontWeight="SemiBold" />
                                </Grid>
                            </Grid>

                            <DockPanel Grid.Row="1" Margin="0,10,0,6">
                                <TextBlock DockPanel.Dock="Left" Text="分析パネル" FontSize="12" FontWeight="SemiBold" Foreground="#23374D" />
                                <TextBlock DockPanel.Dock="Right" Text="出来高 / MACD / RSI" FontSize="10" Foreground="#60788F" />
                            </DockPanel>

                            <ItemsControl Grid.Row="2"
                                          ItemsSource="{Binding VisibleJapaneseIndicatorPanels}"
                                          Style="{StaticResource VisibleJapaneseIndicatorPanelsStyle}"
                                          ItemTemplate="{StaticResource IndicatorPanelTemplate}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                            </ItemsControl>

                            <TextBlock Grid.Row="3"
                                       Text="表示中の分析パネルがありません。"
                                       Margin="0,4,0,0"
                                       VerticalAlignment="Top"
                                       Style="{StaticResource HiddenWhenIndicatorPanelsExistTextStyle}" />
                        </Grid>
                    </Border>
                </Grid>
                </ScrollViewer>
            </Border>

            <GridSplitter Grid.Column="1" Width="6" Style="{StaticResource SidebarSplitterStyle}" />

            <Border Grid.Column="2" MinWidth="300" Style="{StaticResource SidebarHostBorderStyle}">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <ContentControl Content="{Binding}" ContentTemplate="{StaticResource SidebarSummaryTemplate}" />

                        <Expander Header="価格通知" IsExpanded="False" Style="{StaticResource SidebarExpanderStyle}">
                            <StackPanel Margin="10,6,10,10">
                                <TextBlock Text="指定価格を上回る、または下回ると Windows 通知を表示します。" TextWrapping="Wrap" Margin="0,0,0,8" Style="{StaticResource MutedCaptionTextStyle}" />
                                <TextBox Text="{Binding AlertThresholdText, UpdateSourceTrigger=PropertyChanged}" Padding="8,4" ToolTip="例: 3000" />
                                <CheckBox IsChecked="{Binding IsPriceAlertEnabled}" Content="価格通知を有効化" Margin="0,8,0,0" Foreground="#23374D" />
                            </StackPanel>
                        </Expander>

                        <Expander Header="同業比較" IsExpanded="True" Style="{StaticResource SidebarExpanderStyle}">
                            <StackPanel Margin="10,6,10,10">
                                <ItemsControl ItemsSource="{Binding SectorComparisonItems}"
                                              Style="{StaticResource VisibleSectorComparisonItemsStyle}"
                                              ItemTemplate="{StaticResource SectorComparisonItemTemplate}" />
                                <TextBlock Text="同業比較データを取得できませんでした。"
                                           Margin="0,4,0,0"
                                           Style="{StaticResource HiddenWhenSectorComparisonExistsTextStyle}" />
                            </StackPanel>
                        </Expander>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>

        <Border Grid.Row="3" Padding="8,6" Background="#F9FBFE" CornerRadius="8" Margin="0,8,0,0">
            <TextBlock Text="{Binding StatusMessage, Mode=OneWay}" Foreground="#2C3E50" VerticalAlignment="Center"
                       TextWrapping="Wrap" Style="{StaticResource ReadOnlyInfoTextStyle}" />
        </Border>
    </Grid>
</Window>