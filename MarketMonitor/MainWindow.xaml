<Window x:Class="MarketMonitor.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Market Monitor" Height="520" Width="900"
        MinHeight="500" MinWidth="820">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Resources/MainWindowStyles.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Padding="16" Background="#0E2A47" CornerRadius="10" Margin="0,0,0,12">
            <StackPanel>
                <TextBlock Text="Market Monitor" FontSize="24" FontWeight="Bold" Foreground="White" />
                <TextBlock Text="東証プライム銘柄の現在値とチャートを監視" FontSize="13" Foreground="#D8E9FA" Margin="0,4,0,0" />
            </StackPanel>
        </Border>

        <Border Grid.Row="1" Padding="12" Background="#F5F8FC" CornerRadius="10" Margin="0,0,0,12">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="220" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="120" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Row="0" Grid.ColumnSpan="6" Text="東証プライム銘柄の銘柄名・コードを入力して Enter または手動更新を押してください。"
                           Foreground="#60788F" Margin="0,0,0,10" />

                <TextBlock Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" Margin="0,0,8,0" Text="銘柄名/コード" FontWeight="SemiBold" />
                <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding Symbol, UpdateSourceTrigger=PropertyChanged}" Padding="8,4" Margin="0,0,12,0"
                         ToolTip="例: 7203 / トヨタ / 三菱商事">
                    <TextBox.InputBindings>
                        <KeyBinding Key="Enter" Command="{Binding RefreshCommand}" />
                    </TextBox.InputBindings>
                </TextBox>

                <TextBlock Grid.Row="1" Grid.Column="2" VerticalAlignment="Center" Margin="0,0,8,0" Text="自動更新(秒)" FontWeight="SemiBold" />
                <TextBox Grid.Row="1" Grid.Column="3" Text="{Binding AutoUpdateIntervalSeconds, UpdateSourceTrigger=PropertyChanged}" Padding="8,4" Margin="0,0,12,0"
                         ToolTip="10秒未満を入力した場合は10秒に補正します。" />

                <Button Grid.Row="1" Grid.Column="4" Content="手動更新" Command="{Binding RefreshCommand}" Padding="14,6" Margin="0,0,8,0" />
                <Button Grid.Row="1" Grid.Column="5" Content="自動更新 ON/OFF" Command="{Binding ToggleAutoUpdateCommand}" Padding="14,6" />
            </Grid>
        </Border>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="5*" />
                <ColumnDefinition Width="8" />
                <ColumnDefinition Width="280" MinWidth="220" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Padding="16" Background="White" CornerRadius="10" BorderBrush="#DCE5F0" BorderThickness="1" Margin="0,0,8,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <DockPanel Margin="0,0,0,8">
                        <TextBlock DockPanel.Dock="Left" Text="チャート" FontSize="14" FontWeight="SemiBold" Foreground="#23374D" />
                        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                            <Button Content="日足" Command="{Binding ShowDailyCandlesCommand}" Style="{StaticResource DailyCandleButtonStyle}" Margin="0,0,6,0" />
                            <Button Content="週足" Command="{Binding ShowWeeklyCandlesCommand}" Style="{StaticResource WeeklyCandleButtonStyle}" />
                        </StackPanel>
                    </DockPanel>

                    <Grid Grid.Row="1" Grid.ColumnSpan="2" Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="表示期間" VerticalAlignment="Center" Margin="0,0,8,0" Foreground="#60788F" FontSize="12" />
                            <Button Content="1か月" Command="{Binding ShowOneMonthCandlesCommand}" Style="{StaticResource OneMonthButtonStyle}" Margin="0,0,6,0" />
                            <Button Content="3か月" Command="{Binding ShowThreeMonthsCandlesCommand}" Style="{StaticResource ThreeMonthsButtonStyle}" Margin="0,0,6,0" />
                            <Button Content="6か月" Command="{Binding ShowSixMonthsCandlesCommand}" Style="{StaticResource SixMonthsButtonStyle}" Margin="0,0,6,0" />
                            <Button Content="1年" Command="{Binding ShowOneYearCandlesCommand}" Style="{StaticResource OneYearButtonStyle}" />
                        </StackPanel>

                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="12,0,12,0">
                            <TextBlock Text="表示指標" VerticalAlignment="Center" Margin="0,0,8,0" Foreground="#60788F" FontSize="12" />
                            <ItemsControl ItemsSource="{Binding JapaneseChartIndicatorOptions}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel Orientation="Horizontal" />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <CheckBox IsChecked="{Binding IsSelected}" Margin="0,0,10,0" VerticalAlignment="Center">
                                            <StackPanel Orientation="Horizontal">
                                                <Rectangle Width="10" Height="2" Fill="{Binding AccentColor}" VerticalAlignment="Center" Margin="0,0,6,0" />
                                                <TextBlock Text="{Binding DisplayName}" Foreground="#23374D" FontSize="12" VerticalAlignment="Center" />
                                            </StackPanel>
                                        </CheckBox>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>

                        <Border Grid.Column="2" Padding="10,4" Background="#EEF4FB" CornerRadius="999" BorderBrush="#D4E0ED" BorderThickness="1">
                            <StackPanel Orientation="Horizontal">
                                <StackPanel Orientation="Horizontal" Margin="0,0,10,0">
                                    <Ellipse Width="8" Height="8" Fill="#D62828" VerticalAlignment="Center" />
                                    <TextBlock Text="陽線" Margin="6,0,0,0" FontSize="11" Foreground="#60788F" VerticalAlignment="Center" />
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,10,0">
                                    <Ellipse Width="8" Height="8" Fill="#1D4ED8" VerticalAlignment="Center" />
                                    <TextBlock Text="陰線" Margin="6,0,0,0" FontSize="11" Foreground="#60788F" VerticalAlignment="Center" />
                                </StackPanel>
                                <ItemsControl ItemsSource="{Binding VisibleJapaneseChartIndicators}">
                                    <ItemsControl.Style>
                                        <Style TargetType="ItemsControl">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding HasVisibleJapaneseChartIndicators}" Value="True">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </ItemsControl.Style>
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <StackPanel Orientation="Horizontal" />
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal" Margin="0,0,10,0">
                                                <Canvas Width="12" Height="8" Margin="0,0,6,0">
                                                    <Polyline Points="0,4 12,4" Stroke="{Binding StrokeColor}" StrokeThickness="{Binding StrokeThickness}"
                                                              StrokeDashArray="{Binding StrokeDashArray}" StrokeLineJoin="Round"
                                                              StrokeStartLineCap="Round" StrokeEndLineCap="Round" />
                                                </Canvas>
                                                <TextBlock Text="{Binding LegendLabel}" FontSize="11" Foreground="#60788F" VerticalAlignment="Center" />
                                            </StackPanel>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <Grid Grid.Row="2" Grid.ColumnSpan="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Grid Grid.Column="0" Margin="0,0,12,20">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Text="{Binding JapaneseCandlestickYAxisTitle}" Foreground="#60788F" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,8" />
                            <Grid Grid.Row="1">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0" Text="{Binding JapaneseCandlestickMaxPriceLabel}" FontSize="11" Foreground="#60788F" />
                                <TextBlock Grid.Row="1" Text="{Binding JapaneseCandlestickMidPriceLabel}" FontSize="11" Foreground="#60788F" VerticalAlignment="Center" />
                                <TextBlock Grid.Row="2" Text="{Binding JapaneseCandlestickMinPriceLabel}" FontSize="11" Foreground="#60788F" VerticalAlignment="Bottom" />
                            </Grid>
                        </Grid>

                        <Border Grid.Column="1" Background="#F7FAFD" CornerRadius="8" Padding="12" BorderBrush="#E2EBF4" BorderThickness="1">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <Grid Grid.Row="0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>

                                    <Border Grid.Column="0" Width="1" Background="#AEBFD1" Margin="0,4,14,26" />

                                    <Grid Grid.Column="1">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="*" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>

                                        <Grid Grid.Row="0" IsHitTestVisible="False">
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="*" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>

                                            <Border Grid.Row="0" Height="1" Background="#D7E3EF" VerticalAlignment="Top" />
                                            <Border Grid.Row="1" Height="1" Background="#DDE7F1" VerticalAlignment="Center" />
                                            <Border Grid.Row="2" Height="1" Background="#D7E3EF" VerticalAlignment="Bottom" />
                                        </Grid>

                                        <ScrollViewer Grid.Row="0" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                                            <Grid Width="{Binding JapaneseCandlestickCanvasWidth}">
                                                <ItemsControl ItemsSource="{Binding VisibleJapaneseChartIndicators}" Width="{Binding JapaneseCandlestickCanvasWidth}" Height="220" IsHitTestVisible="False">
                                                    <ItemsControl.ItemsPanel>
                                                        <ItemsPanelTemplate>
                                                            <Grid />
                                                        </ItemsPanelTemplate>
                                                    </ItemsControl.ItemsPanel>
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <Polyline Points="{Binding Points}" Stroke="{Binding StrokeColor}" StrokeThickness="{Binding StrokeThickness}"
                                                                      StrokeDashArray="{Binding StrokeDashArray}" StrokeLineJoin="Round"
                                                                      StrokeStartLineCap="Round" StrokeEndLineCap="Round" Opacity="0.95" />
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>

                                                <ItemsControl ItemsSource="{Binding JapaneseCandlesticks}">
                                                    <ItemsControl.ItemsPanel>
                                                        <ItemsPanelTemplate>
                                                            <StackPanel Orientation="Horizontal" />
                                                        </ItemsPanelTemplate>
                                                    </ItemsControl.ItemsPanel>
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <Border Width="34" Padding="4,4,4,0" CornerRadius="6" Background="Transparent" BorderBrush="Transparent" BorderThickness="1">
                                                                <Border.Style>
                                                                    <Style TargetType="Border">
                                                                        <Setter Property="Background" Value="Transparent" />
                                                                        <Setter Property="BorderBrush" Value="Transparent" />
                                                                        <Style.Triggers>
                                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                                <Setter Property="Background" Value="#EAF2FB" />
                                                                                <Setter Property="BorderBrush" Value="#BDD1E5" />
                                                                            </Trigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </Border.Style>
                                                                <StackPanel Width="26" ToolTipService.ShowDuration="60000">
                                                                    <StackPanel.ToolTip>
                                                                        <ToolTip Placement="Mouse" HasDropShadow="True">
                                                                            <StackPanel>
                                                                                <TextBlock Text="{Binding DateText, StringFormat=日付: {0}}" FontWeight="SemiBold" Margin="0,0,0,6" />
                                                                                <TextBlock Text="{Binding OpenText, StringFormat=始値: {0}}" />
                                                                                <TextBlock Text="{Binding CloseText, StringFormat=終値: {0}}" />
                                                                                <TextBlock Text="{Binding HighText, StringFormat=高値: {0}}" />
                                                                                <TextBlock Text="{Binding LowText, StringFormat=安値: {0}}" />
                                                                            </StackPanel>
                                                                        </ToolTip>
                                                                    </StackPanel.ToolTip>
                                                                    <Canvas Width="26" Height="220">
                                                                        <Rectangle Width="2" Height="{Binding WickHeight}" Fill="{Binding WickColor}"
                                                                                   Canvas.Left="12" Canvas.Top="{Binding WickTop}" />
                                                                        <Rectangle Width="12" Height="{Binding BodyHeight}" Fill="{Binding BodyColor}"
                                                                                   Stroke="#22303C" StrokeThickness="0.7"
                                                                                   RadiusX="1.5" RadiusY="1.5"
                                                                                   Canvas.Left="7" Canvas.Top="{Binding BodyTop}" />
                                                                    </Canvas>
                                                                    <TextBlock Text="{Binding Label}" FontSize="9" FontWeight="SemiBold" HorizontalAlignment="Center" Foreground="#60788F" TextAlignment="Center" Margin="0,6,0,0">
                                                                        <TextBlock.Style>
                                                                            <Style TargetType="TextBlock">
                                                                                <Setter Property="Visibility" Value="Collapsed" />
                                                                                <Style.Triggers>
                                                                                    <DataTrigger Binding="{Binding IsLabelVisible}" Value="True">
                                                                                        <Setter Property="Visibility" Value="Visible" />
                                                                                    </DataTrigger>
                                                                                </Style.Triggers>
                                                                            </Style>
                                                                        </TextBlock.Style>
                                                                    </TextBlock>
                                                                </StackPanel>
                                                            </Border>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </Grid>
                                        </ScrollViewer>

                                        <Border Grid.Row="1" Height="1" Background="#AEBFD1" Margin="0,8,0,0" />
                                    </Grid>
                                </Grid>

                                <TextBlock Grid.Row="1" Text="{Binding JapaneseCandlestickXAxisTitle}" Foreground="#60788F" FontSize="12" FontWeight="SemiBold" HorizontalAlignment="Right" Margin="0,12,4,0" />
                            </Grid>
                        </Border>
                    </Grid>
                </Grid>
            </Border>

            <GridSplitter Grid.Column="1" Width="8" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Background="Transparent" ResizeBehavior="PreviousAndNext" ResizeDirection="Columns" ShowsPreview="True" />

            <Border Grid.Column="2" Padding="14" Background="White" CornerRadius="10" BorderBrush="#DCE5F0" BorderThickness="1" VerticalAlignment="Top">
                <StackPanel>
                    <TextBox Text="{Binding CompanyDisplay, Mode=OneWay}" FontSize="13" FontWeight="SemiBold"
                             Foreground="#60788F" IsReadOnly="True" BorderThickness="0" Background="Transparent" />
                    <TextBlock Text="現在値" FontSize="15" FontWeight="SemiBold" Foreground="#23374D" Margin="0,8,0,0" />
                    <TextBox Text="{Binding StockPriceDisplay, Mode=OneWay}" FontSize="32" FontWeight="Bold" Margin="0,10,0,0"
                             Foreground="#0E2A47" IsReadOnly="True" BorderThickness="0" Background="Transparent" />
                    <TextBox Text="{Binding StockUpdatedAtDisplay, Mode=OneWay}" FontSize="12" Foreground="#60788F" Margin="0,8,0,0"
                             IsReadOnly="True" BorderThickness="0" Background="Transparent" />
                </StackPanel>
            </Border>
        </Grid>

        <Border Grid.Row="3" Padding="10" Background="#F9FBFE" CornerRadius="8" Margin="0,12,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBox Grid.Column="0" Text="{Binding StatusMessage, Mode=OneWay}" Foreground="#2C3E50" VerticalAlignment="Center"
                         IsReadOnly="True" BorderThickness="0" Background="Transparent" TextWrapping="Wrap" />
                <TextBlock Grid.Column="1" Text="{Binding IsAutoUpdateEnabled, StringFormat=自動更新: {0}}" Foreground="#2C3E50" VerticalAlignment="Center" FontWeight="SemiBold" />
            </Grid>
        </Border>
    </Grid>
</Window>
