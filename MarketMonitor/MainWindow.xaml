<Window x:Class="MarketMonitor.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:MarketMonitor.ViewModels"
        mc:Ignorable="d"
        Title="Market Monitor" Height="520" Width="900"
        MinHeight="500" MinWidth="820">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Padding="16" Background="#0E2A47" CornerRadius="10" Margin="0,0,0,12">
            <StackPanel>
                <TextBlock Text="Market Monitor" FontSize="24" FontWeight="Bold" Foreground="White" />
                <TextBlock Text="為替と株価の現在値を監視" FontSize="13" Foreground="#D8E9FA" Margin="0,4,0,0" />
            </StackPanel>
        </Border>

        <Border Grid.Row="1" Padding="12" Background="#F5F8FC" CornerRadius="10" Margin="0,0,0,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="220" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="120" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" VerticalAlignment="Center" Margin="0,0,8,0" Text="銘柄名/コード" FontWeight="SemiBold" />
                <TextBox Grid.Column="1" Text="{Binding Symbol, UpdateSourceTrigger=PropertyChanged}" Padding="8,4" Margin="0,0,12,0">
                    <TextBox.InputBindings>
                        <KeyBinding Key="Enter" Command="{Binding RefreshCommand}" />
                    </TextBox.InputBindings>
                </TextBox>

                <TextBlock Grid.Column="2" VerticalAlignment="Center" Margin="0,0,8,0" Text="自動更新(秒)" FontWeight="SemiBold" />
                <TextBox Grid.Column="3" Text="{Binding AutoUpdateIntervalSeconds, UpdateSourceTrigger=PropertyChanged}" Padding="8,4" Margin="0,0,12,0" />

                <Button Grid.Column="4" Content="手動更新" Command="{Binding RefreshCommand}" Padding="14,6" Margin="0,0,8,0" />
                <Button Grid.Column="5" Content="自動更新切替" Command="{Binding ToggleAutoUpdateCommand}" Padding="14,6" />
            </Grid>
        </Border>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Padding="16" Background="White" CornerRadius="10" BorderBrush="#DCE5F0" BorderThickness="1" Margin="0,0,6,0">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Visibility" Value="Visible" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsJapaneseStock}" Value="True">
                                <Setter Property="Visibility" Value="Collapsed" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <StackPanel>
                    <TextBlock Text="為替 (USD/JPY)" FontSize="15" FontWeight="SemiBold" Foreground="#23374D" />
                    <TextBox Text="{Binding ExchangeRateDisplay, Mode=OneWay}" FontSize="40" FontWeight="Bold" Margin="0,12,0,0"
                             Foreground="#0E2A47" IsReadOnly="True" BorderThickness="0" Background="Transparent" />
                    <TextBox Text="{Binding ExchangeUpdatedAtDisplay, Mode=OneWay}" FontSize="12" Foreground="#60788F" Margin="0,8,0,0"
                             IsReadOnly="True" BorderThickness="0" Background="Transparent" />
                </StackPanel>
            </Border>

            <Border Grid.Column="1" Padding="16" Background="White" CornerRadius="10" BorderBrush="#DCE5F0" BorderThickness="1" Margin="6,0,0,0">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Grid.Column" Value="1" />
                        <Setter Property="Grid.ColumnSpan" Value="1" />
                        <Setter Property="Margin" Value="6,0,0,0" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsJapaneseStock}" Value="True">
                                <Setter Property="Grid.Column" Value="0" />
                                <Setter Property="Grid.ColumnSpan" Value="2" />
                                <Setter Property="Margin" Value="0" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <StackPanel>
                    <TextBlock Text="株価" FontSize="15" FontWeight="SemiBold" Foreground="#23374D" />
                    <TextBox Text="{Binding StockPriceDisplay, Mode=OneWay}" FontSize="40" FontWeight="Bold" Margin="0,12,0,0"
                             Foreground="#0E2A47" IsReadOnly="True" BorderThickness="0" Background="Transparent" />
                    <TextBox Text="{Binding StockUpdatedAtDisplay, Mode=OneWay}" FontSize="12" Foreground="#60788F" Margin="0,8,0,0"
                             IsReadOnly="True" BorderThickness="0" Background="Transparent" />
                </StackPanel>
            </Border>
        </Grid>

        <Border Grid.Row="3" Padding="10" Background="#F9FBFE" CornerRadius="8" Margin="0,12,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBox Grid.Column="0" Text="{Binding StatusMessage, Mode=OneWay}" Foreground="#2C3E50" VerticalAlignment="Center"
                         IsReadOnly="True" BorderThickness="0" Background="Transparent" TextWrapping="Wrap" />
                <TextBlock Grid.Column="1" Text="{Binding IsAutoUpdateEnabled, StringFormat=自動更新: {0}}" Foreground="#2C3E50" VerticalAlignment="Center" FontWeight="SemiBold" />
            </Grid>
        </Border>
    </Grid>
</Window>
