<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="MainWindowVisibilityStyles.xaml" />
        <ResourceDictionary Source="MainWindowTemplates.xaml" />
    </ResourceDictionary.MergedDictionaries>

    <Style x:Key="SegmentButtonBaseStyle" TargetType="Button">
        <Setter Property="Background" Value="#F4F7FB" />
        <Setter Property="Foreground" Value="#31465B" />
        <Setter Property="BorderBrush" Value="#C7D6E6" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Padding" Value="8,3" />
    </Style>

    <Style x:Key="DailyCandleButtonStyle" TargetType="Button" BasedOn="{StaticResource SegmentButtonBaseStyle}">
        <Style.Triggers>
            <DataTrigger Binding="{Binding DataContext.IsDailyCandleSelected, RelativeSource={RelativeSource AncestorType=Window}}" Value="True">
                <Setter Property="Background" Value="#D62828" />
                <Setter Property="Foreground" Value="White" />
                <Setter Property="BorderBrush" Value="#A61E1E" />
                <Setter Property="FontWeight" Value="Bold" />
            </DataTrigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="WeeklyCandleButtonStyle" TargetType="Button" BasedOn="{StaticResource SegmentButtonBaseStyle}">
        <Style.Triggers>
            <DataTrigger Binding="{Binding DataContext.IsWeeklyCandleSelected, RelativeSource={RelativeSource AncestorType=Window}}" Value="True">
                <Setter Property="Background" Value="#1D4ED8" />
                <Setter Property="Foreground" Value="White" />
                <Setter Property="BorderBrush" Value="#1E3A8A" />
                <Setter Property="FontWeight" Value="Bold" />
            </DataTrigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="OneMonthButtonStyle" TargetType="Button" BasedOn="{StaticResource SegmentButtonBaseStyle}">
        <Style.Triggers>
            <DataTrigger Binding="{Binding DataContext.IsOneMonthSelected, RelativeSource={RelativeSource AncestorType=Window}}" Value="True">
                <Setter Property="Background" Value="#0E7490" />
                <Setter Property="Foreground" Value="White" />
                <Setter Property="BorderBrush" Value="#155E75" />
                <Setter Property="FontWeight" Value="Bold" />
            </DataTrigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="ThreeMonthsButtonStyle" TargetType="Button" BasedOn="{StaticResource SegmentButtonBaseStyle}">
        <Style.Triggers>
            <DataTrigger Binding="{Binding DataContext.IsThreeMonthsSelected, RelativeSource={RelativeSource AncestorType=Window}}" Value="True">
                <Setter Property="Background" Value="#0E7490" />
                <Setter Property="Foreground" Value="White" />
                <Setter Property="BorderBrush" Value="#155E75" />
                <Setter Property="FontWeight" Value="Bold" />
            </DataTrigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="SixMonthsButtonStyle" TargetType="Button" BasedOn="{StaticResource SegmentButtonBaseStyle}">
        <Style.Triggers>
            <DataTrigger Binding="{Binding DataContext.IsSixMonthsSelected, RelativeSource={RelativeSource AncestorType=Window}}" Value="True">
                <Setter Property="Background" Value="#0E7490" />
                <Setter Property="Foreground" Value="White" />
                <Setter Property="BorderBrush" Value="#155E75" />
                <Setter Property="FontWeight" Value="Bold" />
            </DataTrigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="OneYearButtonStyle" TargetType="Button" BasedOn="{StaticResource SegmentButtonBaseStyle}">
        <Style.Triggers>
            <DataTrigger Binding="{Binding DataContext.IsOneYearSelected, RelativeSource={RelativeSource AncestorType=Window}}" Value="True">
                <Setter Property="Background" Value="#0E7490" />
                <Setter Property="Foreground" Value="White" />
                <Setter Property="BorderBrush" Value="#155E75" />
                <Setter Property="FontWeight" Value="Bold" />
            </DataTrigger>
        </Style.Triggers>
    </Style>
</ResourceDictionary>
